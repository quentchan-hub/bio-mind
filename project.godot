run/main_scene="uid://e01tv4ge5kyh"
config/features=PackedStringArray("4.5", "C#", "Forward Plus")
config/icon="uid://d0rougdkkl0xu"
config/macos_native_icon="res://Icons/Biomind_icon.icns"
